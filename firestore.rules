rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY PRIMITIVES ---
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- 1. USERS COLLECTION ---
    match /users/{userId} {
      allow read: if true; // Public profiles for discovery
      allow create: if isValidId(userId) && isValidUser(incoming());
      allow update: if isValidId(userId) && isValidUser(incoming());
      allow delete: if true;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'createdAt'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.email is string && data.email.size() <= 250
        && (!data.keys().hasAny(['bio']) || (data.bio is string && data.bio.size() <= 5000))
        && (!data.keys().hasAny(['profileImage']) || (data.profileImage is string && data.profileImage.size() <= 3500000))
        && (!data.keys().hasAny(['coverImage']) || (data.coverImage is string && data.coverImage.size() <= 3500000))
        && (!data.keys().hasAny(['location']) || (data.location is string && data.location.size() <= 500))
        && (!data.keys().hasAny(['interests']) || (data.interests is list && data.interests.size() <= 50))
        && (!data.keys().hasAny(['socialLinks']) || data.socialLinks is map)
        && (!data.keys().hasAny(['savedPosts']) || (data.savedPosts is list && data.savedPosts.size() <= 500))
        && (!data.keys().hasAny(['hasSetupAccount']) || data.hasSetupAccount is bool)
        && (!data.keys().hasAny(['isBlocked']) || data.isBlocked is bool)
        && (!data.keys().hasAny(['role']) || data.role is string)
        && (!data.keys().hasAny(['isAdmin']) || data.isAdmin is bool)
        && (!data.keys().hasAny(['phoneNumber']) || (data.phoneNumber is string && data.phoneNumber.size() <= 100))
        && (!data.keys().hasAny(['panNumber']) || (data.panNumber is string && data.panNumber.size() <= 100))
        && (!data.keys().hasAny(['officialDocId']) || (data.officialDocId is string && data.officialDocId.size() <= 200))
        && (!data.keys().hasAny(['idPhoto']) || (data.idPhoto is string && data.idPhoto.size() <= 3500000))
        && (!data.keys().hasAny(['isApprovedByAdmin']) || data.isApprovedByAdmin is bool)
        && (!data.keys().hasAny(['walletBalance']) || (data.walletBalance is int || data.walletBalance is float))
        && (!data.keys().hasAny(['walletCredits']) || (data.walletCredits is int || data.walletCredits is float))
        && (!data.keys().hasAny(['isMonetizationEnabled']) || data.isMonetizationEnabled is bool)
        && (!data.keys().hasAny(['monthlySubscriptionPrice']) || (data.monthlySubscriptionPrice is int || data.monthlySubscriptionPrice is float))
        && (!data.keys().hasAny(['subscribedCreators']) || data.subscribedCreators is list)
        && (!data.keys().hasAny(['clearanceRemarks']) || data.clearanceRemarks is string)
        && (!data.keys().hasAny(['hasVerifiedDetails']) || data.hasVerifiedDetails is bool)
        && (!data.keys().hasAny(['dob']) || (data.dob is string && data.dob.size() <= 50))
        && (!data.keys().hasAny(['hasPassedMonetizationQuiz']) || data.hasPassedMonetizationQuiz is bool)
        && (!data.keys().hasAny(['subscribedTiers']) || data.subscribedTiers is map)
        && (!data.keys().hasAny(['notificationSettings']) || data.notificationSettings is map);
    }

    // --- 2. POSTS COLLECTION ---
    match /posts/{postId} {
      allow read: if true; // Public discovery
      allow create: if isValidId(postId) && isValidPost(incoming());
      allow update: if isValidId(postId) && isValidPost(incoming());
      allow delete: if true;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['id', 'userId', 'title', 'content', 'category', 'status', 'createdAt', 'readingTime'])
        && data.id is string
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.content is string && data.content.size() <= 150000
        && data.category is string && data.category.size() <= 50
        && (!data.keys().hasAny(['tags']) || (data.tags is list && data.tags.size() <= 25))
        && (!data.keys().hasAny(['mediaUrl']) || (data.mediaUrl is string && data.mediaUrl.size() <= 3500000))
        && (!data.keys().hasAny(['mediaUrls']) || data.mediaUrls is list)
        && (!data.keys().hasAny(['videoUrl']) || (data.videoUrl is string && data.videoUrl.size() <= 3500000))
        && (!data.keys().hasAny(['isPremium']) || data.isPremium is bool)
        && (data.status == 'published' || data.status == 'draft')
        && (data.readingTime is int || data.readingTime is float);
    }

    // --- 3. LIKES COLLECTION ---
    match /likes/{likeId} {
      allow read: if true;
      allow create: if isValidId(likeId) && isValidLike(incoming());
      allow update: if isValidId(likeId) && isValidLike(incoming());
      allow delete: if true;
    }

    function isValidLike(data) {
      return data.keys().hasAll(['userId', 'postId'])
        && data.postId is string && data.postId.size() <= 128
        && (!data.keys().hasAny(['reactionType']) || (data.reactionType is string && data.reactionType.size() <= 50));
    }

    // --- 4. COMMENTS COLLECTION ---
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isValidId(commentId) && isValidComment(incoming());
      allow update: if isValidId(commentId) && isValidComment(incoming());
      allow delete: if true;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['id', 'userId', 'postId', 'comment', 'createdAt'])
        && data.postId is string && data.postId.size() <= 128
        && data.comment is string && data.comment.size() > 0 && data.comment.size() <= 5000
        && (!data.keys().hasAny(['updatedAt']) || data.updatedAt is string);
    }

    // --- 5. FOLLOWERS COLLECTION ---
    match /followers/{followerId_followingId} {
      allow read: if true;
      allow create: if isValidId(followerId_followingId) && isValidFollower(incoming());
      allow update: if isValidId(followerId_followingId) && isValidFollower(incoming());
      allow delete: if true;
    }

    function isValidFollower(data) {
      return data.keys().hasAll(['followerId', 'followingId'])
        && data.followingId is string && data.followingId.size() <= 128;
    }

    // --- 6. MESSAGES COLLECTION ---
    match /messages/{messageId} {
      allow read: if true;
      allow create: if isValidId(messageId) && isValidMessage(incoming());
      allow update: if isValidId(messageId) && isValidMessage(incoming());
      allow delete: if true;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['id', 'senderId', 'receiverId', 'message', 'createdAt', 'read'])
        && data.senderId is string && data.senderId.size() <= 128
        && data.receiverId is string && data.receiverId.size() <= 128
        && data.message is string && data.message.size() <= 10000
        && data.read is bool
        && (!data.keys().hasAny(['mediaUrl']) || (data.mediaUrl is string && data.mediaUrl.size() <= 3500000))
        && (!data.keys().hasAny(['status']) || (data.status == 'sent' || data.status == 'delivered' || data.status == 'seen'))
        && (!data.keys().hasAny(['updatedAt']) || data.updatedAt is string);
    }

    // --- 7. WITHDRAWALS COLLECTION ---
    match /withdrawals/{withdrawalId} {
      allow read: if true;
      allow create: if isValidId(withdrawalId) && isValidWithdrawal(incoming());
      allow update: if isValidId(withdrawalId) && isValidWithdrawal(incoming());
      allow delete: if true;
    }

    function isValidWithdrawal(data) {
      return data.keys().hasAll(['id', 'userId', 'amountNpr', 'paymentMethod', 'details', 'status', 'createdAt'])
        && data.id is string
        && (data.amountNpr is int || data.amountNpr is float)
        && data.paymentMethod is string
        && data.details is string
        && (data.status == 'pending' || data.status == 'approved' || data.status == 'rejected')
        && (!data.keys().hasAny(['remarks']) || data.remarks is string)
        && data.createdAt is string;
    }

    // --- 8. NOTIFICATIONS COLLECTION ---
    match /notifications/{notifId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // --- 9. POST REPORTS COLLECTION ---
    match /postReports/{reportId} {
      allow read: if true;
      allow create: if isValidId(reportId);
      allow update: if true;
      allow delete: if true;
    }

    // --- 10. ADS COLLECTION ---
    match /ads/{adId} {
      allow read: if true;
      allow create: if isValidId(adId);
      allow update: if true;
      allow delete: if true;
    }

    // --- 11. DRAFTS COLLECTION ---
    match /drafts/{draftId} {
      allow read: if true;
      allow create: if isValidId(draftId) && isValidDraft(incoming());
      allow update: if isValidId(draftId) && isValidDraft(incoming());
      allow delete: if true;
    }

    function isValidDraft(data) {
      return data.keys().hasAll(['id', 'userId', 'updatedAt'])
        && data.id is string
        && data.userId is string
        && data.updatedAt is string
        && (!data.keys().hasAny(['title']) || data.title is string)
        && (!data.keys().hasAny(['content']) || data.content is string)
        && (!data.keys().hasAny(['category']) || data.category is string)
        && (!data.keys().hasAny(['tagsString']) || data.tagsString is string)
        && (!data.keys().hasAny(['multiplePhotos']) || data.multiplePhotos is list)
        && (!data.keys().hasAny(['videoUrl']) || data.videoUrl is string)
        && (!data.keys().hasAny(['isPremium']) || data.isPremium is bool)
        && (!data.keys().hasAny(['imageRatio']) || data.imageRatio is string)
        && (!data.keys().hasAny(['hasPoll']) || data.hasPoll is bool)
        && (!data.keys().hasAny(['pollQuestion']) || data.pollQuestion is string)
        && (!data.keys().hasAny(['pollOptions']) || data.pollOptions is list);
    }
  }
}
